  SAVED_HTTPS_PORT=$(cat "${OPENCLAW_CONFIG_DIR}/.https_port" 2>/dev/null || echo "")
  if [[ -n "$SAVED_HTTPS_PORT" ]] && systemctl is-active --quiet caddy 2>/dev/null; then
    HTTPS_ACTIVE=true
