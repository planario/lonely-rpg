#!/usr/bin/env bash
###############################################################################
#  OpenClaw + Local LLM — Instalador Onipotente para Linux
#  Compatível com: Ubuntu/Debian, Fedora/RHEL/CentOS
#
#  O que este script faz (100 % não-interativo):
#    1. Detecta a distro e instala dependências (Node 20+, curl, git, jq …)
#    2. Analisa o hardware (RAM, CPU, GPU NVIDIA/AMD/Intel) e seleciona
#       automaticamente o melhor modelo LLM para o seu sistema
#    3. Instala o Ollama e baixa o modelo escolhido
#    4. Instala o OpenClaw via npm e cria serviço systemd
#    5. Configura o OpenClaw para usar o Ollama local como backend LLM
#    6. Cria 4 agentes especializados (Manager, Backend Dev, Frontend Dev, QA)
#    7. Aplica limites de CPU/RAM para não fritar o servidor
#    8. Instala o utilitário 'openclaw-ctl' para controle fácil dos serviços
#    9. Configura HTTPS via Caddy reverse proxy (certificado auto-assinado)
#   10. Libera portas no firewall (ufw / firewalld), trata SELinux
#   11. Exibe URL + token para acesso imediato via navegador
#
#  Uso:
#    chmod +x openclaw-fullstack-installer.sh
#    sudo ./openclaw-fullstack-installer.sh            # Instalar
#    sudo ./openclaw-fullstack-installer.sh --uninstall # Desinstalar tudo
#
#  Após a instalação, use 'openclaw-ctl' para gerenciar:
#    openclaw-ctl start   — Inicia todos os serviços
#    openclaw-ctl stop    — Para tudo (libera recursos)
#    openclaw-ctl status  — Mostra status de todos os serviços
#    openclaw-ctl restart — Reinicia tudo
#    openclaw-ctl logs    — Logs em tempo real
###############################################################################
set -euo pipefail
IFS=$'\n\t'

# ─── Trap para debug: mostra a última linha executada se o script abortar ────
trap 'err "Script abortou na linha $LINENO (último comando: $BASH_COMMAND, exit code: $?)"' ERR

# ─── Cores ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

log()  { echo -e "${GREEN}[OK]${NC}    $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()  { echo -e "${RED}[ERRO]${NC}  $*" >&2; }
info() { echo -e "${CYAN}[INFO]${NC}  $*"; }
banner() {
  echo ""
  echo -e "${BOLD}${CYAN}=======================================${NC}"
  echo -e "${BOLD}${CYAN}  $*${NC}"
  echo -e "${BOLD}${CYAN}=======================================${NC}"
  echo ""
}

# ─── Verificação de root ─────────────────────────────────────────────────────
if [[ $EUID -ne 0 ]]; then
  err "Este script precisa ser executado como root (sudo)."
  exit 1
fi

# Usuário real (quem chamou sudo)
REAL_USER="${SUDO_USER:-$USER}"
REAL_HOME=$(eval echo "~${REAL_USER}")

# ─── Variáveis globais ──────────────────────────────────────────────────────
OPENCLAW_CONFIG_DIR="${REAL_HOME}/.openclaw"
OPENCLAW_WORKSPACE_DIR="${OPENCLAW_CONFIG_DIR}/workspace"
OPENCLAW_CTL_PATH="/usr/local/bin/openclaw-ctl"
OLLAMA_MODEL=""  # Será definido automaticamente por detect_hardware()
OLLAMA_NUM_CTX=4096
OLLAMA_PORT=11434
GATEWAY_PORT=18789
HTTPS_PORT=443
DISTRO=""
PKG_MGR=""

# ─── Variáveis de hardware (preenchidas por detect_hardware) ────────────────
HW_RAM_GB=0
HW_CPU_CORES=0
HW_CPU_MODEL=""
HW_GPU_VENDOR=""      # nvidia | amd | intel | none
HW_GPU_MODEL=""
HW_GPU_VRAM_MB=0
HW_TIER=""            # minimal | low | mid | high | ultra
HW_MODEL_REASON=""

# ─── Modo de instalação ──────────────────────────────────────────────────────
INSTALL_MODE="local"        # local | remote
REMOTE_PROVIDER=""          # openai | gemini | groq | mistral | openrouter | together | custom
REMOTE_PROVIDER_NAME=""     # nome para exibição
REMOTE_BASE_URL=""          # endpoint OpenAI-compatível do provedor
REMOTE_API_KEY=""           # chave de API (nunca gravada em disco)
REMOTE_MODEL=""             # nome do modelo no provedor

###############################################################################
# 0. SELEÇÃO DO MODO DE INSTALAÇÃO
###############################################################################
select_install_mode() {
  echo ""
  echo -e "${BOLD}${CYAN}=======================================${NC}"
  echo -e "${BOLD}${CYAN}  Tipo de instalação${NC}"
  echo -e "${BOLD}${CYAN}=======================================${NC}"
  echo ""
  echo -e "  Como os agentes de IA devem se comunicar?"
  echo ""
  echo -e "  ${BOLD}${GREEN}[1]${NC} ${BOLD}Local Code Team${NC}  ${DIM}(padrão)${NC}"
  echo -e "      LLM roda ${GREEN}localmente${NC} no servidor via Ollama"
  echo -e "      ${DIM}Sem custos de API — requer hardware adequado (min 4 GB RAM)${NC}"
  echo ""
  echo -e "  ${BOLD}${CYAN}[2]${NC} ${BOLD}Remote Code Team${NC}"
  echo -e "      LLM na ${CYAN}nuvem${NC} — escolha o provedor (OpenAI, Gemini, Groq...)"
  echo -e "      ${DIM}Requer chave de API — sem requisitos de hardware na máquina${NC}"
  echo ""

  local choice
  read -r -p "  Digite sua escolha [1/2] (padrão: 1): " choice

  case "${choice:-1}" in
    1) INSTALL_MODE="local"  ; log "Modo selecionado: Local Code Team"  ;;
    2) INSTALL_MODE="remote" ; log "Modo selecionado: Remote Code Team" ;;
    *)
      warn "Opção inválida. Usando modo Local."
      INSTALL_MODE="local"
      ;;
  esac
  echo ""
}

# ─── Helper: lista de modelos numerada ───────────────────────────────────────
_select_model_from_list() {
  local models=("$@")
  echo ""
  echo -e "  ${BOLD}Modelos disponíveis:${NC}"
  local i=1
  for m in "${models[@]}"; do
    echo -e "    ${GREEN}[${i}]${NC} ${m}"
    ((i++))
  done
  echo -e "    ${GREEN}[${i}]${NC} Digitar manualmente"
  echo ""

  local choice
  read -r -p "  Selecione o modelo [1-${i}] (padrão: 1): " choice
  choice="${choice:-1}"

  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice < i )); then
    REMOTE_MODEL="${models[$((choice - 1))]}"
  elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice == i )); then
    read -r -p "  Digite o nome do modelo: " REMOTE_MODEL
  else
    REMOTE_MODEL="${models[0]}"
    warn "Opção inválida. Usando: ${REMOTE_MODEL}"
  fi

  log "Modelo: ${REMOTE_MODEL}"
}

# ─── Valida a chave de API com uma chamada de teste ──────────────────────────
_validate_remote_api() {
  banner "Validando chave de API"
  info "Testando conexão com ${REMOTE_PROVIDER_NAME} (modelo: ${REMOTE_MODEL})..."

  local payload
  payload='{"model":"'"${REMOTE_MODEL}"'","messages":[{"role":"user","content":"hi"}],"max_tokens":1}'

  local raw_response http_code body
  raw_response=$(curl -s --max-time 20 \
    -X POST "${REMOTE_BASE_URL}/chat/completions" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${REMOTE_API_KEY}" \
    -d "$payload" \
    -w "\n__HTTP_CODE__%{http_code}" 2>/dev/null) || true

  http_code=$(echo "$raw_response" | grep "__HTTP_CODE__" | sed 's/__HTTP_CODE__//')
  body=$(echo "$raw_response" | grep -v "__HTTP_CODE__")

  case "$http_code" in
    200)
      log "Chave de API válida. Conexão com ${REMOTE_PROVIDER_NAME} confirmada."
      ;;
    401|403)
      err "Chave de API inválida ou sem permissão (HTTP ${http_code})."
      err "Verifique sua chave e tente novamente."
      if [[ -n "$body" ]]; then err "Detalhe: $(echo "$body" | head -3)"; fi
      exit 1
      ;;
    404)
      err "Modelo '${REMOTE_MODEL}' não encontrado no provedor (HTTP 404)."
      err "Verifique o nome exato do modelo para ${REMOTE_PROVIDER_NAME}."
      if [[ -n "$body" ]]; then err "Detalhe: $(echo "$body" | head -3)"; fi
      exit 1
      ;;
    429)
      warn "Rate limit atingido (HTTP 429) — chave válida, muitas requisições simultâneas."
      warn "Continuando instalação..."
      ;;
    "")
      err "Sem resposta do servidor. Verifique a URL base: ${REMOTE_BASE_URL}"
      err "e se há conexão com a internet."
      exit 1
      ;;
    *)
      warn "Resposta inesperada da API: HTTP ${http_code}."
      warn "Continuando. Se os agentes não funcionarem, verifique modelo e URL base."
      ;;
  esac
}

