###############################################################################
# 14. INSTALAÇÃO DO openclaw-ctl (CONTROLE CENTRALIZADO)
###############################################################################
install_openclaw_ctl() {
  banner "Instalando utilitário openclaw-ctl"

  cat > "$OPENCLAW_CTL_PATH" <<'CTLEOF'
#!/usr/bin/env bash
###############################################################################
#  openclaw-ctl — Controle centralizado da stack OpenClaw + Ollama
#
#  Uso:
#    openclaw-ctl start    — Inicia todos os serviços (Ollama + Gateway)
#    openclaw-ctl stop     — Para todos os serviços (libera CPU/RAM/GPU)
#    openclaw-ctl restart  — Reinicia tudo
#    openclaw-ctl status   — Mostra status detalhado
#    openclaw-ctl logs     — Logs em tempo real (Ctrl+C para sair)
#    openclaw-ctl logs ollama|gateway  — Logs de um serviço específico
#    openclaw-ctl info     — Mostra URLs de acesso e token
#    openclaw-ctl approve  — Aprova dispositivos pendentes (fix 'pairing required')
###############################################################################
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'; DIM='\033[2m'

SERVICES=("ollama" "openclaw-gateway" "caddy")

_need_sudo() {
  if [[ $EUID -ne 0 ]]; then
    echo -e "${YELLOW}Este comando precisa de sudo.${NC}"
    exec sudo "$0" "$@"
  fi
}

_svc_status_line() {
  local svc="$1"
  local active mem cpu
  active=$(systemctl is-active "$svc" 2>/dev/null || echo "inactive")

  if [[ "$active" == "active" ]]; then
    # Obtém uso de memória e CPU do cgroup
    mem=$(systemctl show "$svc" --property=MemoryCurrent 2>/dev/null | cut -d= -f2)
    if [[ -n "$mem" && "$mem" != "[not set]" && "$mem" -gt 0 ]] 2>/dev/null; then
      mem="$(( mem / 1048576 ))M"
    else
      mem="-"
    fi
    cpu=$(systemctl show "$svc" --property=CPUUsageNSec 2>/dev/null | cut -d= -f2)
    if [[ -n "$cpu" && "$cpu" != "[not set]" && "$cpu" -gt 0 ]] 2>/dev/null; then
      cpu="$(( cpu / 1000000 ))ms total"
    else
      cpu="-"
    fi
    echo -e "  ${GREEN}●${NC} ${BOLD}${svc}${NC}  ${DIM}RAM: ${mem}  CPU: ${cpu}${NC}"
  else
    echo -e "  ${RED}○${NC} ${BOLD}${svc}${NC}  ${DIM}(${active})${NC}"
  fi
}

cmd_start() {
  _need_sudo "$@"
  echo -e "${CYAN}Iniciando stack OpenClaw...${NC}"
  for svc in "${SERVICES[@]}"; do
    systemctl start "$svc" 2>/dev/null && \
      echo -e "  ${GREEN}✓${NC} ${svc}" || \
      echo -e "  ${RED}✗${NC} ${svc} (falhou)"
  done
  echo ""
  echo -e "${GREEN}Stack iniciada.${NC} Use ${BOLD}openclaw-ctl status${NC} para verificar."
}

cmd_stop() {
  _need_sudo "$@"
  echo -e "${YELLOW}Parando stack OpenClaw (liberando recursos)...${NC}"
  # Para na ordem inversa (gateway primeiro, depois ollama)
  for svc in $(echo "${SERVICES[@]}" | tr ' ' '\n' | tac); do
    systemctl stop "$svc" 2>/dev/null && \
      echo -e "  ${GREEN}✓${NC} ${svc} parado" || \
      echo -e "  ${DIM}  ${svc} já estava parado${NC}"
  done
  echo ""
  echo -e "${GREEN}Todos os serviços parados. Recursos liberados.${NC}"
}

cmd_restart() {
  _need_sudo "$@"
  echo -e "${CYAN}Reiniciando stack OpenClaw...${NC}"
  for svc in "${SERVICES[@]}"; do
    systemctl restart "$svc" 2>/dev/null && \
      echo -e "  ${GREEN}✓${NC} ${svc}" || \
      echo -e "  ${RED}✗${NC} ${svc} (falhou)"
  done
  echo -e "${GREEN}Stack reiniciada.${NC}"
}

cmd_status() {
  echo ""
  echo -e "${BOLD}${CYAN}═══ OpenClaw Stack Status ═══${NC}"
  echo ""
  for svc in "${SERVICES[@]}"; do
    _svc_status_line "$svc"
  done

  # Mostra modelos carregados no Ollama
  echo ""
  if systemctl is-active --quiet ollama 2>/dev/null; then
    local models
    models=$(curl -sf http://localhost:11434/api/ps 2>/dev/null | \
      python3 -c "import sys,json;d=json.load(sys.stdin);[print(f'  {m[\"name\"]} ({m[\"size\"]//1048576}M VRAM)') for m in d.get('models',[])]" 2>/dev/null || true)
    if [[ -n "$models" ]]; then
      echo -e "${BOLD}Modelos carregados na memória:${NC}"
      echo "$models"
    else
      echo -e "${DIM}Nenhum modelo carregado na memória (será carregado no primeiro uso).${NC}"
    fi
  fi
  echo ""
}

cmd_logs() {
  local target="${1:-all}"
  case "$target" in
    ollama)
      journalctl -u ollama -f --no-hostname
      ;;
    gateway|openclaw|openclaw-gateway)
      journalctl -u openclaw-gateway -f --no-hostname
      ;;
    all|*)
      journalctl -u ollama -u openclaw-gateway -f --no-hostname
      ;;
  esac
}

cmd_info() {
  local config_dir="$HOME/.openclaw"
  if [[ ! -f "${config_dir}/.gw_token" ]]; then
    # Tenta no /root se não encontrou no home do user
    for d in /root/.openclaw /home/*/.openclaw; do
      if [[ -f "${d}/.gw_token" ]]; then
        config_dir="$d"
        break
      fi
    done
  fi

  local token local_ip public_ip
  token=$(cat "${config_dir}/.gw_token" 2>/dev/null || echo "???")
  local_ip=$(cat "${config_dir}/.local_ip" 2>/dev/null || hostname -I 2>/dev/null | awk '{print $1}' || echo "???")
  public_ip=$(cat "${config_dir}/.public_ip" 2>/dev/null || echo "")
  local port
  port=$(systemctl show openclaw-gateway --property=Environment 2>/dev/null | \
    grep -oP 'OPENCLAW_GATEWAY_PORT=\K[0-9]+' || echo "18789")

  local https_port
  https_port=$(cat "${config_dir}/.https_port" 2>/dev/null || echo "")

  echo ""
  echo -e "${BOLD}${CYAN}═══ OpenClaw — Informações de Acesso ═══${NC}"
  echo ""

  # HTTPS URLs (se Caddy estiver ativo)
  if [[ -n "$https_port" ]] && systemctl is-active --quiet caddy 2>/dev/null; then
    local hs=""
    [[ "$https_port" != "443" ]] && hs=":${https_port}"
    echo -e "  ${BOLD}${GREEN}HTTPS (acesso remoto):${NC}"
    if [[ -n "$public_ip" && "$public_ip" != "$local_ip" ]]; then
      echo -e "    ${CYAN}https://${public_ip}${hs}?token=${token}${NC}"
    fi
    echo -e "    ${CYAN}https://${local_ip}${hs}?token=${token}${NC}"
    echo ""
  fi

  echo -e "  ${BOLD}HTTP:${NC}"
  if [[ -n "$public_ip" && "$public_ip" != "$local_ip" ]]; then
    echo -e "    ${CYAN}http://${public_ip}:${port}?token=${token}${NC}"
  fi
  echo -e "    ${CYAN}http://${local_ip}:${port}?token=${token}${NC}"
  echo -e "    ${CYAN}http://localhost:${port}?token=${token}${NC}"
  echo ""
  echo -e "  ${BOLD}Token:${NC}   ${YELLOW}${token}${NC}"
  echo ""
}

cmd_approve() {
  echo -e "${CYAN}Aprovando dispositivos pendentes...${NC}"
  # Lista dispositivos pendentes
  local pending
  pending=$(openclaw devices list 2>/dev/null || true)
  if [[ -z "$pending" ]]; then
    echo -e "${DIM}Nenhum dispositivo pendente no momento.${NC}"
    echo ""
    echo -e "Se o navegador mostra 'pairing required':"
    echo -e "  1. Abra a URL no navegador (ela envia um pedido de pairing)"
    echo -e "  2. Execute ${BOLD}openclaw-ctl approve${NC} novamente"
    echo ""
    return 0
  fi
  echo "$pending"
  echo ""
  # Aprova todos os pendentes
  openclaw devices approve 2>/dev/null && \
    echo -e "${GREEN}Dispositivos aprovados com sucesso!${NC}" || \
    echo -e "${YELLOW}Use: openclaw devices list && openclaw devices approve <id>${NC}"
  echo ""
  echo -e "${DIM}Atualize a página do navegador após aprovar.${NC}"
}

cmd_help() {
  echo ""
  echo -e "${BOLD}openclaw-ctl${NC} — Controle da stack OpenClaw + Ollama"
  echo ""
  echo -e "  ${BOLD}Comandos:${NC}"
  echo -e "    ${GREEN}start${NC}     Inicia todos os serviços"
  echo -e "    ${RED}stop${NC}      Para tudo (libera CPU/RAM/GPU)"
  echo -e "    ${CYAN}restart${NC}   Reinicia todos os serviços"
  echo -e "    ${CYAN}status${NC}    Status detalhado com uso de recursos"
  echo -e "    ${CYAN}logs${NC}      Logs em tempo real (Ctrl+C para sair)"
  echo -e "    ${CYAN}logs${NC} ${DIM}ollama|gateway${NC}  Logs de um serviço específico"
  echo -e "    ${CYAN}info${NC}      URLs de acesso e token"
  echo -e "    ${GREEN}approve${NC}   Aprova dispositivos pendentes (fix 'pairing required')"
  echo ""
}

case "${1:-help}" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    cmd_logs "${2:-all}" ;;
  info)    cmd_info ;;
  approve|pair) cmd_approve ;;
  help|-h|--help) cmd_help ;;
  *)
    echo -e "${RED}Comando desconhecido: $1${NC}"
    cmd_help
    exit 1
    ;;
esac
CTLEOF

  chmod +x "$OPENCLAW_CTL_PATH"
  chown root:root "$OPENCLAW_CTL_PATH"

  log "openclaw-ctl instalado em ${OPENCLAW_CTL_PATH}"
  log "Use: openclaw-ctl start | stop | status | restart | logs | info"
}

###############################################################################
# 15. DESINSTALAÇÃO COMPLETA
###############################################################################
do_uninstall() {
  banner "Desinstalação COMPLETA do OpenClaw + Ollama"

  # ─── Calcula espaço ocupado pelos modelos ────────────────────────────────
  local models_dir="${REAL_HOME}/.ollama/models"
  local models_size="0"
  if [[ -d "$models_dir" ]]; then
    models_size=$(du -sh "$models_dir" 2>/dev/null | awk '{print $1}' || echo "?")
  fi

  echo -e "${YELLOW}${BOLD}ATENÇÃO: Esta operação vai remover TUDO que foi instalado:${NC}"
  echo ""
  echo -e "  ${RED}1.${NC} Serviço systemd: ${BOLD}openclaw-gateway${NC}"
  echo -e "  ${RED}2.${NC} Serviço systemd: ${BOLD}ollama${NC} (serviço completo + binário)"
  echo -e "  ${RED}3.${NC} Modelos LLM baixados: ${BOLD}${models_dir}${NC} (${YELLOW}${models_size}${NC})"
  echo -e "  ${RED}4.${NC} Pacote npm global: ${BOLD}openclaw${NC}"
  echo -e "  ${RED}5.${NC} Utilitário: ${BOLD}${OPENCLAW_CTL_PATH}${NC}"
  echo -e "  ${RED}6.${NC} Configurações: ${BOLD}${OPENCLAW_CONFIG_DIR}${NC}"
  echo -e "  ${RED}7.${NC} Caddy (reverse proxy HTTPS) — configuração e certificados"
  echo -e "  ${RED}8.${NC} Regras de firewall e SELinux criadas pela instalação"
  echo ""
  echo -e "  ${DIM}Node.js/npm e Caddy (pacote) NÃO serão removidos (podem ser usados por outros projetos).${NC}"
  echo ""

  # Confirmação
  if [[ "${2:-}" != "--yes" && "${2:-}" != "-y" ]]; then
    echo -en "${BOLD}${RED}Tem certeza que deseja remover TUDO? [s/N]: ${NC}"
    read -r confirm
    if [[ "${confirm,,}" != "s" && "${confirm,,}" != "sim" && "${confirm,,}" != "y" && "${confirm,,}" != "yes" ]]; then
      echo "Desinstalação cancelada."
      exit 0
    fi
  fi

  echo ""

  # ─── 1. Para e remove serviço openclaw-gateway ──────────────────────────
  info "Parando e removendo serviço openclaw-gateway..."
  systemctl stop openclaw-gateway 2>/dev/null || true
  systemctl disable openclaw-gateway 2>/dev/null || true
  rm -f /etc/systemd/system/openclaw-gateway.service

  # Mata processos residuais do gateway (systemctl stop pode não ser suficiente)
  local gw_pids
  gw_pids=$(pgrep -f "openclaw.*gateway" 2>/dev/null || true)
  if [[ -n "$gw_pids" ]]; then
    kill $gw_pids 2>/dev/null || true
    sleep 1
    # Force kill se ainda vivos
    gw_pids=$(pgrep -f "openclaw.*gateway" 2>/dev/null || true)
    if [[ -n "$gw_pids" ]]; then
      kill -9 $gw_pids 2>/dev/null || true
    fi
  fi
  log "Serviço openclaw-gateway removido."

  # ─── 2. Para e remove Ollama completamente ──────────────────────────────
  info "Parando e removendo Ollama completamente..."
  systemctl stop ollama 2>/dev/null || true
  systemctl disable ollama 2>/dev/null || true

  # Mata processos residuais do Ollama
  local ollama_pids
  ollama_pids=$(pgrep -f "ollama" 2>/dev/null || true)
  if [[ -n "$ollama_pids" ]]; then
    kill $ollama_pids 2>/dev/null || true
    sleep 1
    ollama_pids=$(pgrep -f "ollama" 2>/dev/null || true)
    if [[ -n "$ollama_pids" ]]; then
      kill -9 $ollama_pids 2>/dev/null || true
    fi
  fi

  # Remove override de configuração
  rm -f /etc/systemd/system/ollama.service.d/override.conf
  rmdir /etc/systemd/system/ollama.service.d 2>/dev/null || true

  # Remove unit file do Ollama
  rm -f /etc/systemd/system/ollama.service
  rm -f /usr/lib/systemd/system/ollama.service

  # Remove binário do Ollama
  rm -f /usr/local/bin/ollama /usr/bin/ollama

  # Remove usuário/grupo do Ollama (criados pelo instalador oficial)
  if id "ollama" &>/dev/null; then
    userdel ollama 2>/dev/null || true
    log "Usuário 'ollama' removido."
  fi
  if getent group ollama &>/dev/null; then
    groupdel ollama 2>/dev/null || true
  fi

  log "Ollama removido (binário + serviço + usuário)."

  # ─── 3. Remove modelos LLM baixados ─────────────────────────────────────
  info "Removendo modelos LLM baixados..."
  local ollama_data_dir="${REAL_HOME}/.ollama"
  # Também verifica /usr/share/ollama (local padrão quando roda como serviço)
  local ollama_system_dir="/usr/share/ollama/.ollama"

  local total_freed=0
  for d in "$ollama_data_dir" "$ollama_system_dir"; do
    if [[ -d "$d" ]]; then
      local dir_size
      dir_size=$(du -sb "$d" 2>/dev/null | awk '{print $1}' || echo 0)
      total_freed=$((total_freed + dir_size))
      rm -rf "$d"
      log "Removido: ${d}"
    fi
  done

  if ((total_freed > 0)); then
    local freed_human
    freed_human=$(numfmt --to=iec-i --suffix=B "$total_freed" 2>/dev/null || echo "${total_freed} bytes")
    log "Espaço liberado pelos modelos: ${freed_human}"
  else
    log "Nenhum diretório de modelos encontrado."
  fi

  # ─── 4. Remove pacote npm openclaw ──────────────────────────────────────
  info "Removendo pacote npm openclaw..."
  npm uninstall -g openclaw 2>/dev/null || true
  rm -f /usr/local/bin/openclaw 2>/dev/null || true  # remove symlink se existir

  # Limpa cache npm do openclaw
  local npm_cache_dir
  npm_cache_dir=$(npm cache ls openclaw 2>/dev/null | head -1 | awk '{print $1}' || true)
  if [[ -n "$npm_cache_dir" ]]; then
    npm cache clean --force 2>/dev/null || true
  fi

  # Remove possíveis restos no npm global
  local npm_global_dir
  npm_global_dir=$(npm root -g 2>/dev/null || true)
  if [[ -n "$npm_global_dir" && -d "${npm_global_dir}/openclaw" ]]; then
    rm -rf "${npm_global_dir}/openclaw"
    log "Restos do pacote npm removidos de ${npm_global_dir}/openclaw"
  fi
  log "Pacote openclaw removido."

  # ─── 5. Remove openclaw-ctl ─────────────────────────────────────────────
  info "Removendo openclaw-ctl..."
  rm -f "$OPENCLAW_CTL_PATH"
  log "openclaw-ctl removido."

  # ─── 6. Remove configuração Caddy (HTTPS reverse proxy) ────────────────
  info "Removendo configuração Caddy do OpenClaw..."
  systemctl stop caddy 2>/dev/null || true
  # Restaura Caddyfile original se existir backup
  if [[ -f /etc/caddy/Caddyfile.bak-openclaw ]]; then
    mv /etc/caddy/Caddyfile.bak-openclaw /etc/caddy/Caddyfile
    log "Caddyfile original restaurado."
  else
    rm -f /etc/caddy/Caddyfile
  fi
  # Remove certificados gerados
  rm -rf /etc/caddy/certs
  log "Configuração Caddy do OpenClaw removida."
  # Nota: o pacote Caddy em si é mantido (pode ser usado por outros projetos)

  # ─── 7. Remove configurações (com backup) ───────────────────────────────
  info "Removendo diretório de configurações ${OPENCLAW_CONFIG_DIR}..."
  if [[ -d "$OPENCLAW_CONFIG_DIR" ]]; then
    local backup_path="/tmp/openclaw-config-backup-$(date +%Y%m%d-%H%M%S).tar.gz"
    tar czf "$backup_path" -C "$(dirname "$OPENCLAW_CONFIG_DIR")" "$(basename "$OPENCLAW_CONFIG_DIR")" 2>/dev/null || true
    rm -rf "$OPENCLAW_CONFIG_DIR"
    log "Configurações removidas (backup em ${backup_path})."
  fi

  # ─── 8. Remove regras de firewall ───────────────────────────────────────
  info "Removendo regras de firewall..."
  if command -v ufw &>/dev/null && ufw status | grep -q "Status: active"; then
    ufw delete allow 18789/tcp 2>/dev/null || true
    ufw delete allow 11434/tcp 2>/dev/null || true
    ufw delete allow 443/tcp 2>/dev/null || true
    ufw reload >/dev/null 2>&1 || true
    log "Regras ufw removidas."
  fi
  if command -v firewall-cmd &>/dev/null && systemctl is-active --quiet firewalld; then
    firewall-cmd --permanent --remove-port=18789/tcp 2>/dev/null || true
    firewall-cmd --permanent --remove-port=11434/tcp 2>/dev/null || true
    firewall-cmd --permanent --remove-port=443/tcp 2>/dev/null || true
    firewall-cmd --reload >/dev/null 2>&1 || true
    log "Regras firewalld removidas."
  fi

  # ─── 9. Reverte SELinux se aplicável ────────────────────────────────────
  if command -v getenforce &>/dev/null; then
    local se_status
    se_status=$(getenforce 2>/dev/null || echo "Disabled")
    if [[ "$se_status" == "Enforcing" || "$se_status" == "Permissive" ]]; then
      if command -v semanage &>/dev/null; then
        semanage port -d -t http_port_t -p tcp 18789 2>/dev/null || true
        log "Regra SELinux da porta 18789 removida."
      fi
      setsebool -P httpd_can_network_connect 0 2>/dev/null || true
    fi
  fi

  systemctl daemon-reload

  echo ""
  banner "DESINSTALAÇÃO COMPLETA CONCLUÍDA"
  echo -e "  ${GREEN}${BOLD}Tudo foi removido com sucesso:${NC}"
  echo -e "    ${GREEN}✓${NC} OpenClaw Gateway (serviço + pacote npm)"
  echo -e "    ${GREEN}✓${NC} Ollama (serviço + binário + usuário)"
  echo -e "    ${GREEN}✓${NC} Modelos LLM baixados"
  echo -e "    ${GREEN}✓${NC} Caddy (configuração HTTPS + certificados)"
  echo -e "    ${GREEN}✓${NC} Configurações (backup salvo em /tmp/)"
  echo -e "    ${GREEN}✓${NC} Regras de firewall e SELinux"
  echo -e "    ${GREEN}✓${NC} openclaw-ctl"
  echo ""
  if ((total_freed > 0)); then
    echo -e "  ${BOLD}Espaço total liberado:${NC} ${GREEN}${freed_human}${NC}"
    echo ""
  fi
  echo -e "  ${DIM}Node.js/npm foram mantidos (podem ser usados por outros projetos).${NC}"
  echo -e "  ${DIM}Para remover: apt remove nodejs / dnf remove nodejs${NC}"
  echo ""
}

###############################################################################
# MAIN
###############################################################################
main() {
  # ─── Trata flags de linha de comando ────────────────────────────────────
  case "${1:-}" in
    --uninstall|uninstall|--remove|remove)
      do_uninstall "$@"
      exit 0
      ;;
    --help|-h|help)
      echo "Uso:"
      echo "  sudo $0              # Instalar OpenClaw (pergunta o tipo)"
      echo "  sudo $0 --uninstall  # Desinstalar tudo"
      echo ""
      echo "Modos de instalação:"
      echo "  [1] Local Code Team  — LLM local via Ollama (sem custos de API)"
      echo "  [2] Remote Code Team — LLM na nuvem (OpenAI, Gemini, Groq...)"
      echo ""
      echo "Após instalar, use 'openclaw-ctl' para gerenciar os serviços."
      exit 0
      ;;
  esac

  banner "OpenClaw — Instalador Onipotente"
  echo -e "  Início: $(date)"
  echo ""

  # ─── Pergunta o modo ANTES de qualquer instalação ────────────────────────
  select_install_mode

  detect_distro
  resolve_ports
  install_system_deps
  install_nodejs

  if [[ "$INSTALL_MODE" == "local" ]]; then
    detect_hardware
    select_model
    install_ollama
    install_openclaw
    configure_ollama_network
  else
    # Modo remoto: coleta provedor e valida a chave antes de instalar qualquer coisa
    select_remote_provider
    install_openclaw
  fi

  generate_config
  start_openclaw
  install_openclaw_ctl
  install_caddy_https
  configure_firewall
  configure_selinux
  print_summary

  echo -e "  Fim: $(date)"
}

main "$@"
