# 10. INICIAR OPENCLAW GATEWAY VIA SYSTEMD (COM LIMITES DE RECURSOS)
###############################################################################
start_openclaw() {
  banner "Iniciando OpenClaw Gateway como serviço systemd"

  # Localiza o binário openclaw (npm global pode variar por distro)
  local OPENCLAW_BIN
  OPENCLAW_BIN=$(command -v openclaw 2>/dev/null || echo "/usr/local/bin/openclaw")

  if [[ ! -x "$OPENCLAW_BIN" ]]; then
    err "Binário openclaw não encontrado em: ${OPENCLAW_BIN}"
    exit 1
  fi

  # Variáveis de ambiente para o serviço
  local GW_TOKEN
  GW_TOKEN=$(cat "${OPENCLAW_CONFIG_DIR}/.gw_token")

  # ─── Calcula limites de recursos para o Gateway ─────────────────────────
  # O Ollama já foi configurado com limites em configure_ollama_network()
  local total_ram_mb=$((HW_RAM_GB * 1024))
  local gateway_ram_limit_mb=$((total_ram_mb / 8))  # 12.5% da RAM para o gateway
  ((gateway_ram_limit_mb < 256)) && gateway_ram_limit_mb=256

  local cpu_budget=$(( HW_CPU_CORES * 50 ))
  local gateway_cpu_quota=$(( cpu_budget / 4 ))  # 25% do budget de CPU
  ((gateway_cpu_quota < 50)) && gateway_cpu_quota=50

  info "Limites do Gateway: ${gateway_ram_limit_mb}M RAM, ${gateway_cpu_quota}% CPU"

  # Para serviço anterior se existir
  systemctl stop openclaw-gateway 2>/dev/null || true
  systemctl disable openclaw-gateway 2>/dev/null || true

  # Cria unit file systemd — OpenClaw Gateway
  cat > /etc/systemd/system/openclaw-gateway.service <<UNITEOF
[Unit]
Description=OpenClaw AI Gateway
Documentation=https://docs.openclaw.ai
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=simple
User=${REAL_USER}
Group=${REAL_USER}
WorkingDirectory=${REAL_HOME}
ExecStart=${OPENCLAW_BIN} gateway --port ${GATEWAY_PORT} --bind lan
Restart=on-failure
RestartSec=5
TimeoutStartSec=30

# Variáveis de ambiente
Environment="HOME=${REAL_HOME}"
Environment="OPENCLAW_CONFIG_PATH=${OPENCLAW_CONFIG_DIR}/openclaw.json"
Environment="OPENCLAW_GATEWAY_TOKEN=${GW_TOKEN}"
Environment="OPENCLAW_GATEWAY_PORT=${GATEWAY_PORT}"
Environment="OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=true"
Environment="NODE_ENV=production"

# ─── Limites de recursos (não fritar o servidor) ──────────────────────
MemoryMax=${gateway_ram_limit_mb}M
MemoryHigh=$(( gateway_ram_limit_mb * 80 / 100 ))M
CPUQuota=${gateway_cpu_quota}%

# Segurança
NoNewPrivileges=yes
PrivateTmp=yes

# Stdout/Stderr para journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openclaw-gateway

[Install]
WantedBy=multi-user.target
UNITEOF

  log "Unit file systemd criado: /etc/systemd/system/openclaw-gateway.service"

  # Executa doctor --fix como último recurso antes de iniciar o serviço
  # (corrige qualquer chave legada que possa ter sobrado de instalações anteriores)
  HOME="$REAL_HOME" OPENCLAW_CONFIG_PATH="${OPENCLAW_CONFIG_DIR}/openclaw.json" \
    "$OPENCLAW_BIN" doctor --fix 2>/dev/null || true

  systemctl daemon-reload
  systemctl enable openclaw-gateway
  systemctl start openclaw-gateway

  # Aguarda o gateway responder na porta HTTP
  info "Aguardando o Gateway ficar disponível na porta ${GATEWAY_PORT}..."
  local retries=0
  while ! curl -sf "http://127.0.0.1:${GATEWAY_PORT}/" >/dev/null 2>&1 && \
        ! curl -sf "http://127.0.0.1:${GATEWAY_PORT}/healthz" >/dev/null 2>&1; do
    retries=$((retries + 1))
    if ((retries > 60)); then
      warn "Gateway não respondeu em 60s. Verificando status do serviço..."
      systemctl status openclaw-gateway --no-pager -l || true
      echo ""
      warn "Logs recentes:"
      journalctl -u openclaw-gateway -n 30 --no-pager 2>/dev/null || true
      echo ""
      err "Gateway não está respondendo na porta ${GATEWAY_PORT}."
      err "Para depurar: journalctl -u openclaw-gateway -f"
      err "Para tentar manualmente: ${OPENCLAW_BIN} gateway --port ${GATEWAY_PORT} --verbose"
      exit 1
    fi
    # Mostra progresso a cada 5 segundos
    if ((retries % 5 == 0)); then
      local svc_status
      svc_status=$(systemctl is-active openclaw-gateway 2>/dev/null || echo "unknown")
      info "  Aguardando... (${retries}s) — serviço: ${svc_status}"
    fi
    sleep 1
  done

  log "OpenClaw Gateway ativo e respondendo na porta ${GATEWAY_PORT}."
  log "Serviço systemd: openclaw-gateway (inicia automaticamente no boot)"

  # ─── Limpa estado de pairing antigo (reinstalação) e aprova automaticamente ─
  # O OpenClaw exige "device pairing" para permitir conexões ao gateway.
  # Em instalação/reinstalação, limpamos pairing antigo e configuramos
  # auto-aprovação para o primeiro acesso via Control UI.
  info "Configurando pairing do gateway..."

  # Remove pairing stale de instalações anteriores
  rm -f "${OPENCLAW_CONFIG_DIR}/devices/paired.json" \
        "${OPENCLAW_CONFIG_DIR}/devices/pending.json" \
        "${OPENCLAW_CONFIG_DIR}/nodes/paired.json" \
        "${OPENCLAW_CONFIG_DIR}/nodes/pending.json" 2>/dev/null || true

  # Executa doctor --fix para gerar token de gateway se necessário
  su - "$REAL_USER" -c "HOME='${REAL_HOME}' OPENCLAW_CONFIG_PATH='${OPENCLAW_CONFIG_DIR}/openclaw.json' \
    $(command -v openclaw) doctor --fix" 2>/dev/null || true

  # Aguarda um momento para o gateway detectar o estado limpo
  sleep 2

  # Tenta aprovar dispositivos pendentes automaticamente (se houver)
  local approve_output
  approve_output=$(su - "$REAL_USER" -c "HOME='${REAL_HOME}' OPENCLAW_CONFIG_PATH='${OPENCLAW_CONFIG_DIR}/openclaw.json' \
    $(command -v openclaw) devices list 2>/dev/null" || true)
  if [[ -n "$approve_output" ]]; then
    info "Dispositivos pendentes detectados. Aprovando automaticamente..."
    su - "$REAL_USER" -c "HOME='${REAL_HOME}' OPENCLAW_CONFIG_PATH='${OPENCLAW_CONFIG_DIR}/openclaw.json' \
      $(command -v openclaw) devices approve 2>/dev/null" || true
  fi

  log "Pairing configurado. Na primeira conexão pelo navegador:"
  log "  1. Acesse a URL HTTPS com o token"
  log "  2. Se aparecer 'pairing required', execute no servidor:"
  log "     openclaw-ctl approve"
}

###############################################################################
# 11. FIREWALL
###############################################################################
configure_firewall() {
  banner "Configurando firewall"

  # No modo remoto o Ollama não está instalado, então não abrimos a porta dele
  local ports=("${GATEWAY_PORT}/tcp" "${HTTPS_PORT}/tcp")
  [[ "$INSTALL_MODE" == "local" ]] && ports+=("${OLLAMA_PORT}/tcp")

  # --- UFW (Ubuntu/Debian) ---
  if command -v ufw &>/dev/null; then
    if ufw status | grep -q "Status: active"; then
      info "Firewall ufw detectado e ativo. Liberando portas..."
      for p in "${ports[@]}"; do
        ufw allow "$p" comment "OpenClaw stack" >/dev/null 2>&1
        log "  ufw: porta ${p} liberada."
      done
      ufw reload >/dev/null 2>&1
    else
      log "ufw presente mas inativo — nenhuma ação necessária."
    fi
  fi

  # --- firewalld (Fedora/RHEL) ---
  if command -v firewall-cmd &>/dev/null; then
    if systemctl is-active --quiet firewalld; then
      info "Firewall firewalld detectado e ativo. Liberando portas..."
      for p in "${ports[@]}"; do
        firewall-cmd --permanent --add-port="$p" >/dev/null 2>&1
        log "  firewalld: porta ${p} liberada."
      done
      firewall-cmd --reload >/dev/null 2>&1
    else
      log "firewalld presente mas inativo — nenhuma ação necessária."
    fi
  fi

  # --- iptables fallback ---
  if ! command -v ufw &>/dev/null && ! command -v firewall-cmd &>/dev/null; then
    if command -v iptables &>/dev/null; then
      info "Usando iptables diretamente para liberar portas..."
      for p in "${ports[@]}"; do
        local port_num="${p%%/*}"
        iptables -C INPUT -p tcp --dport "$port_num" -j ACCEPT 2>/dev/null \
          || iptables -A INPUT -p tcp --dport "$port_num" -j ACCEPT
        log "  iptables: porta ${port_num} liberada."
      done
    else
      log "Nenhum firewall detectado — nenhuma ação necessária."
    fi
  fi
}

###############################################################################
# 12. SELINUX
###############################################################################
configure_selinux() {
  banner "Verificando SELinux"

  if command -v getenforce &>/dev/null; then
    local se_status
    se_status=$(getenforce 2>/dev/null || echo "Disabled")

    if [[ "$se_status" == "Enforcing" ]]; then
      info "SELinux está em modo Enforcing. Aplicando políticas necessárias..."

      # Permite que os serviços acessem portas customizadas
      if command -v semanage &>/dev/null; then
        semanage port -a -t http_port_t -p tcp "$GATEWAY_PORT" 2>/dev/null || \
          semanage port -m -t http_port_t -p tcp "$GATEWAY_PORT" 2>/dev/null || true
        log "Porta ${GATEWAY_PORT} adicionada ao tipo http_port_t."
      fi

      # Permite que o OpenClaw Gateway conecte na rede (para alcançar Ollama)
      setsebool -P httpd_can_network_connect 1 2>/dev/null || true
      log "httpd_can_network_connect habilitado."

    elif [[ "$se_status" == "Permissive" ]]; then
      log "SELinux em modo Permissive — nenhuma ação bloqueante necessária."
    else
      log "SELinux desabilitado."
    fi
  else
    log "SELinux não presente neste sistema."
  fi
}

###############################################################################
# 13. HTTPS VIA CADDY (REVERSE PROXY COM TLS AUTOMÁTICO)
###############################################################################
install_caddy_https() {
  banner "Configurando HTTPS via Caddy (reverse proxy)"

  # ─── Instala Caddy se não existir ─────────────────────────────────────────
  if ! command -v caddy &>/dev/null; then
    info "Instalando Caddy..."
    if [[ "$DISTRO" == "debian" ]]; then
      apt-get install -y -qq debian-keyring debian-archive-keyring apt-transport-https 2>/dev/null || true
      curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | \
        gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg 2>/dev/null
      curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | \
        tee /etc/apt/sources.list.d/caddy-stable.list >/dev/null
      apt-get update -qq 2>/dev/null
      apt-get install -y -qq caddy
    elif [[ "$DISTRO" == "fedora" ]]; then
      dnf install -y -q 'dnf-command(copr)' 2>/dev/null || true
      dnf copr enable -y @caddy/caddy 2>/dev/null || true
      dnf install -y -q caddy
    fi
  fi

  if ! command -v caddy &>/dev/null; then
    warn "Não foi possível instalar o Caddy automaticamente."
    warn "HTTPS não será configurado. Acesse via HTTP (funciona no localhost)."
    warn "Para VPS, instale o Caddy manualmente: https://caddyserver.com/docs/install"
    return 0
  fi
  log "Caddy instalado: $(caddy version 2>/dev/null || echo 'ok')"

  # ─── Verifica se porta HTTPS está livre ───────────────────────────────────
  if ! check_port "$HTTPS_PORT" "HTTPS/Caddy"; then
    HTTPS_PORT=$(find_free_port "$HTTPS_PORT")
    warn "Porta HTTPS realocada para: ${HTTPS_PORT}"
  fi

  # ─── Detecta IPs ──────────────────────────────────────────────────────────
  local LOCAL_IP
  LOCAL_IP=$(cat "${OPENCLAW_CONFIG_DIR}/.local_ip" 2>/dev/null || hostname -I 2>/dev/null | awk '{print $1}')
  local PUBLIC_IP
  PUBLIC_IP=$(cat "${OPENCLAW_CONFIG_DIR}/.public_ip" 2>/dev/null || echo "")

  # ─── Gera certificado auto-assinado (funciona sem domínio) ────────────────
  local CADDY_CERT_DIR="/etc/caddy/certs"
  mkdir -p "$CADDY_CERT_DIR"

  # Monta lista de SANs (Subject Alternative Names) para o certificado
  local SAN_LIST="IP:127.0.0.1,IP:${LOCAL_IP}"
  [[ -n "$PUBLIC_IP" ]] && SAN_LIST="${SAN_LIST},IP:${PUBLIC_IP}"

  if [[ ! -f "${CADDY_CERT_DIR}/openclaw.crt" ]]; then
    info "Gerando certificado TLS auto-assinado..."
    openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 \
      -days 3650 -nodes \
      -keyout "${CADDY_CERT_DIR}/openclaw.key" \
      -out "${CADDY_CERT_DIR}/openclaw.crt" \
      -subj "/CN=OpenClaw Local" \
      -addext "subjectAltName=${SAN_LIST}" \
      2>/dev/null
    chmod 640 "${CADDY_CERT_DIR}/openclaw.key"
    chown caddy:caddy "${CADDY_CERT_DIR}/openclaw.key" "${CADDY_CERT_DIR}/openclaw.crt" 2>/dev/null || true
    log "Certificado auto-assinado gerado (válido por 10 anos)."
  else
    log "Certificado TLS já existe — reutilizando."
  fi

  # ─── Cria Caddyfile ──────────────────────────────────────────────────────
  local CADDYFILE="/etc/caddy/Caddyfile"

  # Backup do Caddyfile original se existir
  [[ -f "$CADDYFILE" && ! -f "${CADDYFILE}.bak-openclaw" ]] && \
    cp "$CADDYFILE" "${CADDYFILE}.bak-openclaw"

  cat > "$CADDYFILE" <<CADDYEOF
# ─── OpenClaw HTTPS Reverse Proxy ─────────────────────────────────────
# Gerado automaticamente pelo instalador OpenClaw.
#
# Para usar Let's Encrypt com domínio próprio, substitua o bloco abaixo por:
#
#   seu-dominio.com {
#       reverse_proxy 127.0.0.1:${GATEWAY_PORT}
#   }
#
# O Caddy obterá o certificado Let's Encrypt automaticamente.
# ───────────────────────────────────────────────────────────────────────

# HTTPS com certificado auto-assinado (funciona com IP, sem domínio)
:${HTTPS_PORT} {
    tls ${CADDY_CERT_DIR}/openclaw.crt ${CADDY_CERT_DIR}/openclaw.key

    reverse_proxy 127.0.0.1:${GATEWAY_PORT} {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # WebSocket support (para o chat em tempo real)
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websocket 127.0.0.1:${GATEWAY_PORT}
}
CADDYEOF

  log "Caddyfile configurado em ${CADDYFILE}"

  # ─── Salva porta HTTPS para uso posterior ────────────────────────────────
  echo "$HTTPS_PORT" > "${OPENCLAW_CONFIG_DIR}/.https_port"
  chown "$REAL_USER":"$REAL_USER" "${OPENCLAW_CONFIG_DIR}/.https_port"

  # ─── Inicia/reinicia Caddy ──────────────────────────────────────────────
  systemctl stop caddy 2>/dev/null || true

  # Valida configuração antes de iniciar
  if caddy validate --config "$CADDYFILE" 2>/dev/null; then
    log "Caddyfile validado com sucesso."
  else
    warn "Validação do Caddyfile falhou. Tentando iniciar mesmo assim..."
  fi

  systemctl enable --now caddy 2>/dev/null || {
    warn "Falha ao iniciar Caddy via systemd. Tentando manualmente..."
    caddy start --config "$CADDYFILE" 2>/dev/null || true
  }

  # Aguarda Caddy responder
  local retries=0
  while ! curl -sfk "https://127.0.0.1:${HTTPS_PORT}/" >/dev/null 2>&1 && \
        ! curl -sfk "https://127.0.0.1:${HTTPS_PORT}/healthz" >/dev/null 2>&1; do
    retries=$((retries + 1))
    if ((retries > 15)); then
      warn "Caddy não respondeu em 15s na porta ${HTTPS_PORT}."
      warn "O acesso HTTPS pode não funcionar. Verifique: journalctl -u caddy -f"
      return 0
    fi
    sleep 1
  done

  log "Caddy ativo — HTTPS disponível na porta ${HTTPS_PORT}."
  echo ""
  echo -e "  ${BOLD}${GREEN}HTTPS configurado com sucesso!${NC}"
  echo -e "  ${DIM}O certificado é auto-assinado. O navegador mostrará um aviso de segurança${NC}"
  echo -e "  ${DIM}na primeira vez — clique 'Avançado' > 'Prosseguir' para aceitar.${NC}"
  echo ""
  echo -e "  ${DIM}Para usar Let's Encrypt (certificado válido), edite /etc/caddy/Caddyfile${NC}"
  echo -e "  ${DIM}e substitua ':${HTTPS_PORT}' pelo seu domínio (ex: meu-server.com).${NC}"
  echo ""
}

