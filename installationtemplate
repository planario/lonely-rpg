###############################################################################
# 1. DETECÇÃO DE DISTRIBUIÇÃO
###############################################################################
detect_distro() {
  banner "Detectando distribuição Linux"
  if [[ -f /etc/os-release ]]; then
    # shellcheck source=/dev/null
    source /etc/os-release
    case "${ID,,}" in
      ubuntu|debian|linuxmint|pop)
        DISTRO="debian"
        PKG_MGR="apt-get"
        ;;
      fedora|rhel|centos|rocky|alma)
        DISTRO="fedora"
        PKG_MGR="dnf"
        ;;
      *)
        # Tenta detecção por ID_LIKE
        case "${ID_LIKE,,}" in
          *debian*|*ubuntu*) DISTRO="debian"; PKG_MGR="apt-get" ;;
          *fedora*|*rhel*)   DISTRO="fedora"; PKG_MGR="dnf"     ;;
          *)
            err "Distribuição '${ID}' não suportada automaticamente."
            err "Suportadas: Ubuntu, Debian, Fedora, RHEL, CentOS, Rocky, Alma"
            exit 1
            ;;
        esac
        ;;
    esac
    log "Distribuição detectada: ${PRETTY_NAME:-$ID} (família: ${DISTRO})"
  else
    err "Não foi possível detectar a distribuição (/etc/os-release ausente)."
    exit 1
  fi
}

###############################################################################
# 2. DETECÇÃO DE HARDWARE E SELEÇÃO INTELIGENTE DO MODELO
###############################################################################
detect_hardware() {
  banner "Analisando hardware do sistema"

  # ─── RAM ──────────────────────────────────────────────────────────────────
  HW_RAM_GB=$(awk '/MemTotal/ {printf "%d", $2/1024/1024}' /proc/meminfo 2>/dev/null || echo 0)
  log "RAM total: ${HW_RAM_GB} GB"

  # ─── CPU ──────────────────────────────────────────────────────────────────
  HW_CPU_CORES=$(nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null || echo 1)
  HW_CPU_MODEL=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "Desconhecido")
  log "CPU: ${HW_CPU_MODEL} (${HW_CPU_CORES} cores)"

  # ─── GPU — NVIDIA ─────────────────────────────────────────────────────────
  if command -v nvidia-smi &>/dev/null; then
    HW_GPU_VENDOR="nvidia"
    HW_GPU_MODEL=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1 | xargs || echo "NVIDIA desconhecida")
    # VRAM em MB
    HW_GPU_VRAM_MB=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1 | xargs || echo 0)
    log "GPU: ${HW_GPU_MODEL} (NVIDIA, ${HW_GPU_VRAM_MB} MB VRAM)"

  # ─── GPU — AMD (ROCm) ────────────────────────────────────────────────────
  elif command -v rocm-smi &>/dev/null; then
    HW_GPU_VENDOR="amd"
    HW_GPU_MODEL=$(rocm-smi --showproductname 2>/dev/null | grep -i "card" | head -1 | xargs || echo "AMD desconhecida")
    HW_GPU_VRAM_MB=$(rocm-smi --showmeminfo vram 2>/dev/null | grep "Total" | awk '{print int($NF/1048576)}' | head -1 || echo 0)
    if [[ "$HW_GPU_VRAM_MB" -eq 0 ]]; then
      # Fallback: tenta via sysfs
      local amd_vram_bytes
      amd_vram_bytes=$(cat /sys/class/drm/card0/device/mem_info_vram_total 2>/dev/null || echo 0)
      HW_GPU_VRAM_MB=$((amd_vram_bytes / 1048576))
    fi
    log "GPU: ${HW_GPU_MODEL} (AMD ROCm, ${HW_GPU_VRAM_MB} MB VRAM)"

  # ─── GPU — Intel Arc (xe) ────────────────────────────────────────────────
  elif [[ -d /sys/class/drm ]] && lspci 2>/dev/null | grep -iq "VGA.*Intel.*Arc"; then
    HW_GPU_VENDOR="intel"
    HW_GPU_MODEL=$(lspci 2>/dev/null | grep -i "VGA.*Intel" | head -1 | sed 's/.*: //' | xargs || echo "Intel Arc desconhecida")
    # Intel Arc: VRAM estimada via lspci memory region
    local intel_vram_bytes
    intel_vram_bytes=$(cat /sys/class/drm/card0/device/mem_info_vram_total 2>/dev/null || echo 0)
    HW_GPU_VRAM_MB=$((intel_vram_bytes / 1048576))
    log "GPU: ${HW_GPU_MODEL} (Intel, ${HW_GPU_VRAM_MB} MB VRAM)"

  # ─── GPU — Integrada / Nenhuma dedicada ───────────────────────────────────
  else
    HW_GPU_VENDOR="none"
    local gpu_line
    gpu_line=$(lspci 2>/dev/null | grep -i "VGA\|3D\|Display" | head -1 | sed 's/.*: //' || echo "Nenhuma detectada")
    HW_GPU_MODEL="$gpu_line"
    HW_GPU_VRAM_MB=0
    log "GPU: ${HW_GPU_MODEL} (integrada/sem GPU dedicada)"
  fi
}

select_model() {
  banner "Selecionando modelo LLM ideal para o seu hardware"

  local vram_gb=$((HW_GPU_VRAM_MB / 1024))

  # ─── Classificação em tiers ───────────────────────────────────────────────
  #
  # A lógica prioriza VRAM da GPU (melhor indicador de capacidade para LLMs)
  # e usa RAM como fallback para CPU-only inference.
  #
  # Tier       | Condição                              | Modelo
  # -----------|---------------------------------------|---------------------------
  # ultra      | VRAM ≥ 24 GB  OU  RAM ≥ 64 GB        | qwen2.5-coder:32b (maior coder disponível)
  # high       | VRAM ≥ 12 GB  OU  RAM ≥ 32 GB        | qwen2.5-coder:14b
  # mid        | VRAM ≥ 6 GB   OU  RAM ≥ 16 GB        | qwen2.5-coder:7b
  # low        | VRAM ≥ 3 GB   OU  RAM ≥ 8 GB         | qwen2.5-coder:3b
  # minimal    | Abaixo disso                          | qwen2.5-coder:1.5b
  #
  # Nota: qwen2.5-coder é treinado especificamente para código e tem suporte
  # a tool-calling muito mais robusto que o qwen2.5 genérico.
  #

  if [[ "$HW_GPU_VENDOR" != "none" ]] && ((vram_gb >= 24)); then
    HW_TIER="ultra"
    OLLAMA_MODEL="qwen2.5-coder:32b"
    HW_MODEL_REASON="GPU ${HW_GPU_MODEL} com ${vram_gb} GB VRAM — modelo coder 32B (máximo disponível na série coder)"

  elif [[ "$HW_GPU_VENDOR" != "none" ]] && ((vram_gb >= 12)); then
    HW_TIER="high"
    OLLAMA_MODEL="qwen2.5-coder:14b"
    HW_MODEL_REASON="GPU ${HW_GPU_MODEL} com ${vram_gb} GB VRAM suporta o modelo coder 14B"

  elif [[ "$HW_GPU_VENDOR" != "none" ]] && ((vram_gb >= 6)); then
    HW_TIER="mid"
    OLLAMA_MODEL="qwen2.5-coder:7b"
    HW_MODEL_REASON="GPU ${HW_GPU_MODEL} com ${vram_gb} GB VRAM suporta o modelo coder 7B"

  elif [[ "$HW_GPU_VENDOR" != "none" ]] && ((vram_gb >= 3)); then
    HW_TIER="low"
    OLLAMA_MODEL="qwen2.5-coder:3b"
    HW_MODEL_REASON="GPU ${HW_GPU_MODEL} com ${vram_gb} GB VRAM suporta o modelo coder 3B"

  # ─── Fallback: sem GPU dedicada, usa RAM para CPU inference ───────────────
  elif ((HW_RAM_GB >= 64)); then
    HW_TIER="ultra"
    OLLAMA_MODEL="qwen2.5-coder:32b"
    HW_MODEL_REASON="${HW_RAM_GB} GB RAM permite rodar o modelo coder 32B via CPU (mais lento que GPU)"

  elif ((HW_RAM_GB >= 32)); then
    HW_TIER="high"
    OLLAMA_MODEL="qwen2.5-coder:14b"
    HW_MODEL_REASON="${HW_RAM_GB} GB RAM suporta o modelo coder 14B via CPU"

  elif ((HW_RAM_GB >= 16)); then
    HW_TIER="mid"
    OLLAMA_MODEL="qwen2.5-coder:7b"
    HW_MODEL_REASON="${HW_RAM_GB} GB RAM suporta o modelo coder 7B via CPU"

  elif ((HW_RAM_GB >= 8)); then
    HW_TIER="low"
    OLLAMA_MODEL="qwen2.5-coder:3b"
    HW_MODEL_REASON="${HW_RAM_GB} GB RAM suporta o modelo coder 3B via CPU"

  else
    HW_TIER="minimal"
    OLLAMA_MODEL="qwen2.5-coder:1.5b"
    HW_MODEL_REASON="Hardware limitado (${HW_RAM_GB} GB RAM) — usando modelo coder ultra-leve 1.5B"
  fi

  # ─── Ajuste por CPU: se tem muitos cores, pode compensar falta de GPU ────
  if [[ "$HW_GPU_VENDOR" == "none" ]] && ((HW_CPU_CORES >= 16)) && [[ "$HW_TIER" != "ultra" ]]; then
    case "$HW_TIER" in
      minimal)
        if ((HW_RAM_GB >= 6)); then
          HW_TIER="low"
          OLLAMA_MODEL="qwen2.5-coder:3b"
          HW_MODEL_REASON="${HW_MODEL_REASON} + CPU forte (${HW_CPU_CORES} cores) compensa falta de GPU"
        fi
        ;;
      low)
        if ((HW_RAM_GB >= 12)); then
          HW_TIER="mid"
          OLLAMA_MODEL="qwen2.5-coder:7b"
          HW_MODEL_REASON="${HW_MODEL_REASON} + CPU forte (${HW_CPU_CORES} cores) permite subir um tier"
        fi
        ;;
      mid)
        if ((HW_RAM_GB >= 24)); then
          HW_TIER="high"
          OLLAMA_MODEL="qwen2.5-coder:14b"
          HW_MODEL_REASON="${HW_MODEL_REASON} + CPU forte (${HW_CPU_CORES} cores) permite subir um tier"
        fi
        ;;
    esac
  fi

  # ─── Exibe resultado ─────────────────────────────────────────────────────
  echo ""
  echo -e "  ${BOLD}╭─────────────────────────────────────────────────────────────╮${NC}"
  echo -e "  ${BOLD}│          PERFIL DE HARDWARE DETECTADO                       │${NC}"
  echo -e "  ${BOLD}├─────────────────────────────────────────────────────────────┤${NC}"
  printf   "  ${BOLD}│${NC} %-14s %-44s ${BOLD}│${NC}\n" "RAM:" "${HW_RAM_GB} GB"
  printf   "  ${BOLD}│${NC} %-14s %-44s ${BOLD}│${NC}\n" "CPU:" "${HW_CPU_MODEL}"
  printf   "  ${BOLD}│${NC} %-14s %-44s ${BOLD}│${NC}\n" "CPU Cores:" "${HW_CPU_CORES}"
  printf   "  ${BOLD}│${NC} %-14s %-44s ${BOLD}│${NC}\n" "GPU:" "${HW_GPU_MODEL}"
  if [[ "$HW_GPU_VENDOR" != "none" ]]; then
    printf "  ${BOLD}│${NC} %-14s %-44s ${BOLD}│${NC}\n" "VRAM:" "$((HW_GPU_VRAM_MB / 1024)) GB (${HW_GPU_VRAM_MB} MB)"
    printf "  ${BOLD}│${NC} %-14s %-44s ${BOLD}│${NC}\n" "Driver:" "${HW_GPU_VENDOR^^}"
  fi
  echo -e "  ${BOLD}├─────────────────────────────────────────────────────────────┤${NC}"
  printf   "  ${BOLD}│${NC} %-14s ${GREEN}%-44s${NC} ${BOLD}│${NC}\n" "Tier:" "${HW_TIER^^}"
  printf   "  ${BOLD}│${NC} %-14s ${CYAN}%-44s${NC} ${BOLD}│${NC}\n" "Modelo:" "${OLLAMA_MODEL}"
  echo -e "  ${BOLD}├─────────────────────────────────────────────────────────────┤${NC}"
  echo -e "  ${BOLD}│${NC} ${YELLOW}Razão:${NC}"
  # Quebra a razão em linhas de ~56 caracteres
  echo "$HW_MODEL_REASON" | fold -s -w 56 | while IFS= read -r line; do
    printf "  ${BOLD}│${NC}   %-56s ${BOLD}│${NC}\n" "$line"
  done
  echo -e "  ${BOLD}╰─────────────────────────────────────────────────────────────╯${NC}"
  echo ""

  log "Modelo selecionado: ${OLLAMA_MODEL} (tier: ${HW_TIER})"

  # ─── Define janela de contexto por tier ──────────────────────────────────
  # O padrão do Ollama é 2048, insuficiente para os prompts do sistema dos
  # agentes. Usar valores maiores garante que as instruções não sejam truncadas.
  case "$HW_TIER" in
    ultra)   OLLAMA_NUM_CTX=32768 ;;
    high)    OLLAMA_NUM_CTX=16384 ;;
    mid)     OLLAMA_NUM_CTX=8192  ;;
    low)     OLLAMA_NUM_CTX=4096  ;;
    minimal) OLLAMA_NUM_CTX=4096  ;;
    *)       OLLAMA_NUM_CTX=4096  ;;
  esac
  log "Janela de contexto (num_ctx): ${OLLAMA_NUM_CTX} tokens"

  # ─── Aviso para tiers baixos ──────────────────────────────────────────────
  if [[ "$HW_TIER" == "minimal" ]]; then
    warn "Hardware muito limitado detectado. O modelo 1.5B é funcional mas"
    warn "terá respostas mais curtas e menos precisas. Considere adicionar"
    warn "mais RAM ou uma GPU dedicada para melhorar a experiência."
  elif [[ "$HW_TIER" == "low" ]] && [[ "$HW_GPU_VENDOR" == "none" ]]; then
    warn "Rodando via CPU sem GPU dedicada. A inferência será mais lenta."
    warn "Uma GPU com 4+ GB VRAM melhoraria significativamente a velocidade."
  fi
}

###############################################################################
# 3. VERIFICAÇÃO E RESOLUÇÃO DE CONFLITOS DE PORTA
###############################################################################
check_port() {
  local port=$1
  local service_name=$2
  if ss -tlnp 2>/dev/null | grep -q ":${port} "; then
    local pid
    pid=$(ss -tlnp 2>/dev/null | grep ":${port} " | grep -oP 'pid=\K[0-9]+' | head -1)
    local proc_name
    proc_name=$(ps -p "${pid}" -o comm= 2>/dev/null || echo "desconhecido")
    warn "Porta ${port} (${service_name}) já em uso por '${proc_name}' (PID ${pid})"
    return 1
  fi
  return 0
}

find_free_port() {
  local base_port=$1
  local port=$base_port
  while ss -tlnp 2>/dev/null | grep -q ":${port} "; do
    port=$((port + 1))
    if ((port > base_port + 100)); then
      err "Não foi possível encontrar porta livre próxima de ${base_port}"
      exit 1
    fi
  done
  echo "$port"
}

resolve_ports() {
  banner "Verificando conflitos de porta"

  if ! check_port "$OLLAMA_PORT" "Ollama"; then
    warn "Ollama pode já estar rodando — será reutilizado."
  fi

  if ! check_port "$GATEWAY_PORT" "OpenClaw Gateway"; then
    GATEWAY_PORT=$(find_free_port "$GATEWAY_PORT")
    warn "Porta do Gateway realocada para: ${GATEWAY_PORT}"
  else
    log "Porta ${GATEWAY_PORT} (Gateway) livre."
  fi

}

###############################################################################
# 4. INSTALAÇÃO DE DEPENDÊNCIAS DO SISTEMA
###############################################################################
install_system_deps() {
  banner "Instalando dependências do sistema"

  if [[ "$DISTRO" == "debian" ]]; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y -qq \
      curl wget git jq ca-certificates gnupg lsb-release \
      software-properties-common apt-transport-https \
      net-tools procps iproute2 sudo
  elif [[ "$DISTRO" == "fedora" ]]; then
    dnf install -y -q \
      curl wget git jq ca-certificates gnupg2 \
      net-tools procps-ng iproute policycoreutils-python-utils \
      sudo dnf-plugins-core
  fi
  log "Dependências do sistema instaladas."
}

###############################################################################
# 5. INSTALAÇÃO DO NODE.JS (≥ 20)
###############################################################################
install_nodejs() {
  banner "Instalando Node.js"

  local need_install=true
  if command -v node &>/dev/null; then
    local node_major
    node_major=$(node -v | sed 's/v//' | cut -d. -f1)
    if ((node_major >= 20)); then
      log "Node.js já instalado: $(node -v)"
      need_install=false
    else
      warn "Node.js ${node_major} muito antigo. Instalando v20+."
    fi
  fi

  if $need_install; then
    if [[ "$DISTRO" == "debian" ]]; then
      curl -fsSL https://deb.nodesource.com/setup_20.x | bash - >/dev/null 2>&1
      apt-get install -y -qq nodejs
    elif [[ "$DISTRO" == "fedora" ]]; then
      curl -fsSL https://rpm.nodesource.com/setup_20.x | bash - >/dev/null 2>&1
      dnf install -y -q nodejs
    fi
    log "Node.js instalado: $(node -v)"
  fi
}

###############################################################################
# 7. INSTALAÇÃO DO OLLAMA + MODELO LOCAL
###############################################################################
install_ollama() {
  banner "Instalando Ollama + modelo ${OLLAMA_MODEL}"

  if command -v ollama &>/dev/null; then
    log "Ollama já instalado: $(ollama --version 2>/dev/null || echo 'versão desconhecida')"
  else
    info "Baixando e instalando Ollama..."
    # Cria home dir e .ollama com permissões corretas para o usuário ollama
    mkdir -p /usr/share/ollama/.ollama
    # Cria usuário ollama previamente se não existir (evita warning do useradd)
    if ! id "ollama" &>/dev/null; then
      useradd -r -s /bin/false -U -m -d /usr/share/ollama ollama 2>/dev/null || true
    fi
    chown -R ollama:ollama /usr/share/ollama
    curl -fsSL https://ollama.com/install.sh | sh 2>&1 | grep -v "warning: the home directory\|Not copying any file" || true
    # Garante permissões após o instalador (ele pode ter recriado diretórios)
    chown -R ollama:ollama /usr/share/ollama
    log "Ollama instalado com sucesso."
  fi

  # Garante que existe um unit file systemd para o Ollama
  # O instalador oficial do Ollama às vezes falha em criar o serviço
  if ! systemctl list-unit-files ollama.service &>/dev/null || \
     ! systemctl list-unit-files ollama.service 2>/dev/null | grep -q "ollama"; then
    info "Criando unit file systemd para Ollama..."
    cat > /etc/systemd/system/ollama.service <<'OLLAMASVCEOF'
[Unit]
Description=Ollama LLM Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ollama serve
Restart=on-failure
RestartSec=5
Environment="HOME=/usr/share/ollama"
Environment="OLLAMA_HOST=0.0.0.0"
WorkingDirectory=/usr/share/ollama

[Install]
WantedBy=multi-user.target
OLLAMASVCEOF
    systemctl daemon-reload
    log "Unit file do Ollama criado em /etc/systemd/system/ollama.service"
  fi

  # Garante que o serviço Ollama está ativo
  if systemctl is-active --quiet ollama 2>/dev/null; then
    log "Serviço Ollama já está ativo."
  else
    systemctl enable --now ollama 2>/dev/null || {
      info "Iniciando Ollama manualmente em segundo plano..."
      su - "$REAL_USER" -c "ollama serve &" 2>/dev/null || ollama serve &
      sleep 3
    }
    log "Serviço Ollama ativo."
  fi

  # Aguarda API ficar disponível (pode demorar na primeira inicialização)
  info "Aguardando API do Ollama ficar disponível..."
  local retries=0
  local max_retries=90
  while ! curl -sf http://localhost:${OLLAMA_PORT}/api/tags >/dev/null 2>&1; do
    retries=$((retries + 1))
    if ((retries > max_retries)); then
      warn "Ollama não respondeu em ${max_retries} segundos. Diagnóstico:"
      warn "  Status do serviço: $(systemctl is-active ollama 2>/dev/null || echo 'desconhecido')"
      warn "  Porta ${OLLAMA_PORT}: $(ss -tlnp 2>/dev/null | grep ":${OLLAMA_PORT}" || echo 'não encontrada')"
      warn "  Últimas linhas do log:"
      journalctl -u ollama --no-pager -n 10 2>/dev/null || true
      # Tenta reiniciar o serviço uma vez antes de desistir
      info "Tentando reiniciar o serviço Ollama..."
      systemctl restart ollama 2>/dev/null || true
      local retry2=0
      while ! curl -sf http://localhost:${OLLAMA_PORT}/api/tags >/dev/null 2>&1; do
        retry2=$((retry2 + 1))
        if ((retry2 > 30)); then
          err "Ollama não respondeu após reinicialização. Verifique: journalctl -u ollama -n 50"
          exit 1
        fi
        sleep 1
      done
      break
    fi
    # Mostra progresso a cada 15 segundos
    if ((retries % 15 == 0)); then
      info "Ainda aguardando Ollama... (${retries}/${max_retries}s)"
    fi
    sleep 1
  done
  log "API do Ollama disponível na porta ${OLLAMA_PORT}."

  # Baixa o modelo se não existir
  if ollama list 2>/dev/null | grep -q "${OLLAMA_MODEL%%:*}" 2>/dev/null; then
    log "Modelo ${OLLAMA_MODEL} já disponível."
  else
    info "Baixando modelo ${OLLAMA_MODEL} (pode levar alguns minutos)..."
    info "Tamanho do download depende do modelo. Aguarde..."
    if ! ollama pull "$OLLAMA_MODEL"; then
      err "Falha ao baixar o modelo ${OLLAMA_MODEL}."
      err "Verifique sua conexão de internet e tente: ollama pull ${OLLAMA_MODEL}"
      exit 1
    fi
    log "Modelo ${OLLAMA_MODEL} baixado com sucesso."
  fi

  # Verifica se o modelo realmente está disponível
  if ! ollama list 2>/dev/null | grep -q "${OLLAMA_MODEL%%:*}" 2>/dev/null; then
    err "Modelo ${OLLAMA_MODEL} não aparece na lista do Ollama após download."
    err "Tente manualmente: ollama pull ${OLLAMA_MODEL}"
    exit 1
  fi
  log "Modelo ${OLLAMA_MODEL} verificado e pronto para uso."
}

###############################################################################
# 8. CONFIGURAÇÃO DO OLLAMA (rede + limites de recursos)
###############################################################################
configure_ollama_network() {
  banner "Configurando Ollama (rede + limites de recursos)"

  # ─── Calcula limites de recursos proporcionais ao hardware ─────────────
  # Reserva no máximo ~40% da RAM total para o Ollama
  local total_ram_mb=$((HW_RAM_GB * 1024))
  local ollama_ram_limit_mb=$((total_ram_mb * 3 / 8))
  ((ollama_ram_limit_mb < 1024)) && ollama_ram_limit_mb=1024

  # CPU: metade dos cores totais, 75% desse budget para Ollama
  local cpu_budget=$(( HW_CPU_CORES * 50 ))
  local ollama_cpu_quota=$(( cpu_budget * 3 / 4 ))
  ((ollama_cpu_quota < 100)) && ollama_cpu_quota=100

  info "Limites de recursos para Ollama: ${ollama_ram_limit_mb}M RAM, ${ollama_cpu_quota}% CPU"

  mkdir -p /etc/systemd/system/ollama.service.d
  cat > /etc/systemd/system/ollama.service.d/override.conf <<OLLAMAEOF
[Service]
# Aceita conexões de qualquer interface (acesso pela rede local)
Environment="OLLAMA_HOST=0.0.0.0"
# Descarrega modelo da memória após 5 min sem uso (libera RAM/VRAM)
Environment="OLLAMA_KEEP_ALIVE=5m"
# Limita inferências paralelas para economizar recursos
Environment="OLLAMA_NUM_PARALLEL=1"
# Janela de contexto padrão — o default de 2048 trunca os system prompts dos agentes
Environment="OLLAMA_NUM_CTX=${OLLAMA_NUM_CTX}"

# ─── Limites de recursos via systemd (cgroup) ──────────────────────
MemoryMax=${ollama_ram_limit_mb}M
MemoryHigh=$(( ollama_ram_limit_mb * 80 / 100 ))M
CPUQuota=${ollama_cpu_quota}%

# Prioridade I/O mais baixa para não bloquear disco de outros serviços
IOSchedulingClass=best-effort
IOSchedulingPriority=6
# Nice +5 = prioridade menor que processos normais
Nice=5
OLLAMAEOF

  # Salva limites para uso pelo start_openclaw e print_summary
  echo "${ollama_ram_limit_mb}" > "${OPENCLAW_CONFIG_DIR}/.ollama_ram_limit"
  echo "${ollama_cpu_quota}" > "${OPENCLAW_CONFIG_DIR}/.ollama_cpu_quota"

  systemctl daemon-reload
  systemctl restart ollama 2>/dev/null || true

  # Aguarda reinício
  local retries=0
  while ! curl -sf http://localhost:${OLLAMA_PORT}/api/tags >/dev/null 2>&1; do
    retries=$((retries + 1))
    if ((retries > 60)); then
      warn "Ollama demorou para reiniciar; continuando mesmo assim."
      break
    fi
    sleep 1
  done
  log "Ollama escutando em 0.0.0.0:${OLLAMA_PORT} (com limites de recursos)"
}

###############################################################################
# 9. INSTALAÇÃO DO OPENCLAW via npm
###############################################################################
install_openclaw() {
  banner "Instalando OpenClaw via npm"

  # Cria diretórios necessários
  mkdir -p "$OPENCLAW_CONFIG_DIR" "$OPENCLAW_WORKSPACE_DIR"
  chown -R "$REAL_USER":"$REAL_USER" "$OPENCLAW_CONFIG_DIR"

  # Para o serviço do gateway se estiver rodando (evita travar o npm update)
  systemctl stop openclaw-gateway 2>/dev/null || true

  # Instala ou atualiza o pacote npm global
  if command -v openclaw &>/dev/null; then
    local current_ver
    current_ver=$(openclaw --version 2>/dev/null || echo "desconhecida")

    # Verifica se já está na versão mais recente
    local latest_ver
    latest_ver=$(npm view openclaw version 2>/dev/null || echo "")
    if [[ -n "$latest_ver" && "$current_ver" == "$latest_ver" ]]; then
      log "OpenClaw já está na versão mais recente (v${current_ver}). Pulando update."
    else
      info "OpenClaw instalado (v${current_ver}). Atualizando para latest..."
      # Timeout de 120s para evitar que trave indefinidamente
      if timeout 120 npm install -g openclaw@latest --loglevel=error 2>&1; then
        log "OpenClaw atualizado com sucesso."
      else
        warn "npm install travou ou falhou (timeout 120s). Usando versão atual: ${current_ver}"
      fi
    fi
  else
    info "Instalando OpenClaw via npm (openclaw@latest)..."
    if ! timeout 180 npm install -g openclaw@latest --loglevel=error 2>&1; then
      err "Falha ao instalar OpenClaw via npm (timeout 180s)."
      err "Tente manualmente: npm install -g openclaw@latest"
      exit 1
    fi
  fi

  # Verifica que o binário está disponível
  if ! command -v openclaw &>/dev/null; then
    # npm global pode estar fora do PATH quando rodando como root com sudo
    local npm_global_bin
    npm_global_bin=$(npm root -g 2>/dev/null | sed 's|/lib/node_modules||')"/bin"
    if [[ -f "${npm_global_bin}/openclaw" ]]; then
      ln -sf "${npm_global_bin}/openclaw" /usr/local/bin/openclaw
      log "Symlink criado: /usr/local/bin/openclaw -> ${npm_global_bin}/openclaw"
    else
      err "Binário 'openclaw' não encontrado após instalação npm."
      err "Tente manualmente: npm install -g openclaw@latest"
      exit 1
    fi
  fi

  log "OpenClaw instalado: $(openclaw --version 2>/dev/null || echo 'ok')"
}

###############################################################################
# 10. GERAÇÃO DE TOKEN + CONFIGURAÇÃO DO OPENCLAW
###############################################################################
generate_config() {
  banner "Gerando configuração do OpenClaw"

  # Gera token seguro
  local GW_TOKEN
  GW_TOKEN=$(openssl rand -hex 32)

  # ─── Monta o bloco de modelos e a referência primária ────────────────────
  # Este bloco varia conforme o modo de instalação (local = Ollama, remote = API).
  local MODELS_BLOCK PRIMARY_MODEL_REF

  if [[ "$INSTALL_MODE" == "remote" ]]; then
    PRIMARY_MODEL_REF="${REMOTE_PROVIDER}/${REMOTE_MODEL}"
    MODELS_BLOCK="$(printf \
      '"models": {\n    "providers": {\n      "%s": {\n        "baseUrl": "%s",\n        "apiKey": "%s",\n        "api": "openai-completions",\n        "models": [\n          {\n            "id": "%s",\n            "name": "%s"\n          }\n        ]\n      }\n    }\n  }' \
      "${REMOTE_PROVIDER}" "${REMOTE_BASE_URL}" "${REMOTE_API_KEY}" \
      "${REMOTE_MODEL}" "${REMOTE_MODEL}")"
  else
    # Modo local: Ollama rodando na própria máquina
    PRIMARY_MODEL_REF="ollama/${OLLAMA_MODEL}"
    MODELS_BLOCK="$(printf \
      '"models": {\n    "providers": {\n      "ollama": {\n        "baseUrl": "http://127.0.0.1:%d/v1",\n        "apiKey": "ollama-local",\n        "api": "openai-completions",\n        "models": [\n          {\n            "id": "%s",\n            "name": "%s",\n            "options": {\n              "num_ctx": %d\n            }\n          }\n        ]\n      }\n    }\n  }' \
      "${OLLAMA_PORT}" "${OLLAMA_MODEL}" "${OLLAMA_MODEL}" "${OLLAMA_NUM_CTX}")"
  fi

  # Detecta IP privado (LAN) e público (VPS/internet)
  local LOCAL_IP
  LOCAL_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
  LOCAL_IP="${LOCAL_IP:-127.0.0.1}"

  local PUBLIC_IP=""
  PUBLIC_IP=$(curl -sf --max-time 5 https://ifconfig.me 2>/dev/null \
           || curl -sf --max-time 5 https://api.ipify.org 2>/dev/null \
           || curl -sf --max-time 5 https://icanhazip.com 2>/dev/null \
           || echo "")
  # Remove espaços/newlines
  PUBLIC_IP=$(echo "$PUBLIC_IP" | tr -d '[:space:]')

  # Cria arquivo de configuração principal
  cat > "${OPENCLAW_CONFIG_DIR}/openclaw.json" <<JSONEOF
{
  "gateway": {
    "port": ${GATEWAY_PORT},
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${GW_TOKEN}"
    },
    "controlUi": {
      "enabled": true,
      "basePath": "/",
      "allowedOrigins": ["*"],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },
  ${MODELS_BLOCK},
  "agents": {
    "defaults": {
      "model": {
        "primary": "${PRIMARY_MODEL_REF}"
      },
      "memorySearch": {
        "enabled": false
      },
      "subagents": {
        "maxSpawnDepth": 2,
        "maxConcurrent": 4,
        "maxChildrenPerAgent": 3
      }
    },
    "list": [
      {
        "id": "manager",
        "name": "Manager",
        "default": true,
        "identity": {
          "emoji": "📋",
          "theme": "blue"
        },
        "subagents": {
          "allowAgents": ["backend", "frontend", "qa"]
        }
      },
      {
        "id": "backend",
        "name": "Backend Dev",
        "identity": {
          "emoji": "⚙️",
          "theme": "green"
        },
        "subagents": {
          "allowAgents": ["manager", "frontend", "qa"]
        }
      },
      {
        "id": "frontend",
        "name": "Frontend Dev",
        "identity": {
          "emoji": "🎨",
          "theme": "purple"
        },
        "subagents": {
          "allowAgents": ["manager", "backend", "qa"]
        }
      },
      {
        "id": "qa",
        "name": "QA Engineer",
        "identity": {
          "emoji": "🧪",
          "theme": "orange"
        },
        "subagents": {
          "allowAgents": ["manager", "backend", "frontend"]
        }
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["manager", "backend", "frontend", "qa"]
    },
    "sessions": {
      "visibility": "all"
    }
  }
}
JSONEOF

  log "Configuração principal gravada em ${OPENCLAW_CONFIG_DIR}/openclaw.json"

  # ─── Valida a configuração e aplica migrações automáticas se necessário ──
  local OPENCLAW_BIN
  OPENCLAW_BIN=$(command -v openclaw 2>/dev/null || echo "")
  if [[ -n "$OPENCLAW_BIN" && -x "$OPENCLAW_BIN" ]]; then
    log "Validando configuração com 'openclaw doctor'..."
    # Passa HOME correto para que o doctor encontre ~/.openclaw/openclaw.json
    if ! HOME="$REAL_HOME" OPENCLAW_CONFIG_PATH="${OPENCLAW_CONFIG_DIR}/openclaw.json" \
        "$OPENCLAW_BIN" doctor 2>/dev/null; then
      warn "Configuração precisa de ajustes. Executando 'openclaw doctor --fix'..."
      HOME="$REAL_HOME" OPENCLAW_CONFIG_PATH="${OPENCLAW_CONFIG_DIR}/openclaw.json" \
        "$OPENCLAW_BIN" doctor --fix 2>/dev/null || true
